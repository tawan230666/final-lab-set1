# Shared JWT Secret (must be same across services)
JWT_SECRET=your-shared-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=1h

# Auth DB
AUTH_DB_NAME=authdb
AUTH_DB_USER=admin
AUTH_DB_PASSWORD=secret

# Task DB
TASK_DB_NAME=taskdb
TASK_DB_USER=admin
TASK_DB_PASSWORD=secret

# User DB
USER_DB_NAME=userdb
USER_DB_USER=admin
USER_DB_PASSWORD=secret

# Service Ports (local)
AUTH_PORT=3001
TASK_PORT=3002
USER_PORT=3003
